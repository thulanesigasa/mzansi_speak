# Dependencies
node_modules/
venv/
env/
.env

# Build outputs
.next/
out/
build/
dist/

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Temporary IDE files
.vscode/
.idea/

# Application generated files
backend/data/outputs/*
!backend/data/outputs/.gitkeep
backend/*.log
*.log
*.wav
*.mp3

# AI Models & Weights (Do not commit large binary/json files)
# Keep only the small metadata if needed, but usually models are in data/models/
backend/data/models/*
!backend/data/models/.gitkeep

# OS files
.DS_Store
